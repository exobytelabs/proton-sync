# Proton Sync environment variables
# Copy to .env and edit before starting:
#   cp example.env .env

# Timezone for logs, cron schedules, and "uploaded today" stats
TZ=America/Los_Angeles

# Web UI login (leave UI_PASSWORD empty to disable auth)
UI_USERNAME=admin
UI_PASSWORD=change-me

# Default paths — uncomment all three below and the matching lines in
# example.docker-compose.yml to lock via compose. Otherwise use Settings UI.
# PROTON_SYNC_PATHS_LOCKED=1
# SOURCE_DIR=/data
# REMOTE_PATH=protondrive:NAS-Backup

# Optional: keep Flask sessions stable across container recreates
# SECRET_KEY=change-me-to-a-long-random-string